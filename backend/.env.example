# 服务端口
PORT=3001

# 数据库连接（SQLite 示例）
# 开发环境使用相对路径，生产环境建议使用绝对路径
DATABASE_URL="file:./prisma/dev.db"

# JWT 密钥（生产环境必须设置！）
# 可使用以下命令生成随机密钥：openssl rand -hex 32
JWT_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# 前端源地址（用于 CORS 配置，多个用逗号分隔）
FRONTEND_ORIGIN="http://localhost:5173"

# 公开 API 基础 URL
PUBLIC_API_BASE_URL="http://localhost:3001"

# 上传文件存储目录
UPLOAD_DIR="uploads"

# 管理员账户（首次启动会自动创建）
# 生产环境必须修改！
ADMIN_EMAIL="admin@fashionai.local"
ADMIN_PASSWORD="your-admin-password-here"

# 演示账户（首次启动会自动创建）
DEMO_EMAIL="demo@fashionai.local"
DEMO_PASSWORD="your-demo-password-here"

# AI 配置
MOCK_AI="false"
AI_API_BASE_URL="https://api.apiyi.com/v1"
AI_API_KEY="your-api-key-here"
AI_MODEL="nano-banana-2"
AI_IMAGE_DETAIL="high"
AI_REQUEST_TIMEOUT_MS="120000"

# 积分配置
CREDIT_PER_GENERATION="10"
CREDIT_PER_UPSCALE="5"

# 文件上传限制
MAX_UPLOAD_SIZE_MB="5"
